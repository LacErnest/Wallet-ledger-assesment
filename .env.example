# Gabarit de configuration — copier en `.env` et renseigner les vraies valeurs.
# Le `.env` n'est jamais committé : un secret en clair dans l'historique Git est
# considéré comme compromis à vie.

# --- Application ---------------------------------------------------------------
SECRET_KEY=change-me-in-production

# --- Base de données (source de vérité financière) -----------------------------
DATABASE_URL=postgresql+psycopg://wallet:wallet@localhost:5433/wallet
# Base dédiée aux tests, isolée de la base de développement.
TEST_DATABASE_URL=postgresql+psycopg://wallet:wallet@localhost:5433/wallet_test

# --- Cache de lecture (jamais source de vérité) --------------------------------
REDIS_URL=redis://localhost:6380/0

# --- API de change (FX) --------------------------------------------------------
# Laisser vide pour utiliser les taux de repli intégrés (mode hors-ligne).
FX_API_URL=
FX_API_KEY=

# --- Fournisseurs de paiement --------------------------------------------------
# Le secret de webhook sert à vérifier que la confirmation vient bien du
# fournisseur, et pas d'un tiers qui voudrait créditer un compte gratuitement.
# Stripe : cartes bancaires.
STRIPE_API_KEY=
STRIPE_WEBHOOK_SECRET=
# PawaPay : agrégateur mobile money (MTN, Orange). Vide => mode hors-ligne simulé.
PAWAPAY_BASE_URL=https://api.sandbox.pawapay.io
PAWAPAY_API_TOKEN=
PAWAPAY_WEBHOOK_SECRET=

# --- Notifications -------------------------------------------------------------
EMAIL_API_KEY=
EMAIL_FROM=no-reply@wallet.local
SMS_API_KEY=
SMS_FROM=Wallet
