# Gabarit de configuration — copier en `.env` et renseigner les vraies valeurs.
# Le `.env` n'est jamais committé : un secret en clair dans l'historique Git est
# considéré comme compromis à vie.

# --- Application ---------------------------------------------------------------
SECRET_KEY=change-me-in-production

# --- Base de données (source de vérité financière) -----------------------------
DATABASE_URL=postgresql+psycopg://wallet:wallet@localhost:5433/wallet
# Conteneur de test jetable (profil "test" de docker compose), port 5434.
TEST_DATABASE_URL=postgresql+psycopg://wallet:wallet@localhost:5434/wallet_test

# --- Cache de lecture (jamais source de vérité) --------------------------------
REDIS_URL=redis://localhost:6380/0
TEST_REDIS_URL=redis://localhost:6381/0

# --- API de change (FX) --------------------------------------------------------
# Laisser vide pour utiliser les taux de repli intégrés (mode hors-ligne).
FX_API_URL=
FX_API_KEY=

# --- Fournisseurs de paiement --------------------------------------------------
# Le secret de webhook sert à vérifier que la confirmation vient bien du
# fournisseur, et pas d'un tiers qui voudrait créditer un compte gratuitement.
# Stripe : cartes bancaires.
STRIPE_API_KEY=
STRIPE_WEBHOOK_SECRET=
# PawaPay : agrégateur mobile money (MTN, Orange). Vide => mode hors-ligne simulé.
PAWAPAY_BASE_URL=https://api.sandbox.pawapay.io
PAWAPAY_API_TOKEN=
PAWAPAY_WEBHOOK_SECRET=

# --- Notifications -------------------------------------------------------------
EMAIL_API_KEY=
EMAIL_FROM=no-reply@wallet.local
SMS_API_KEY=
SMS_FROM=Wallet

# ==============================================================================
# COMPTES & IDENTIFIANTS DE TEST — POUR USAGE DE TEST UNIQUEMENT
# FOR TEST PURPOSES ONLY. Ne JAMAIS utiliser ces valeurs en production.
# ==============================================================================
# Le système n'a pas d'authentification utilisateur (hors périmètre) : un « compte »
# est identifié par son numéro. `make seed` crée les comptes ci-dessous et affiche
# leurs numéros. On note ici leurs propriétaires (owner_id) pour les retrouver.
SEED_ACCOUNT_USD_PRIMARY=alice          # compte USD financé (200.00)
SEED_ACCOUNT_USD_SECONDARY=bob          # compte USD destinataire
SEED_ACCOUNT_XAF=kamga                  # compte XAF (mobile money)

# Identifiants bac à sable des fournisseurs (clés de TEST, non sensibles) :
# Stripe : clés `sk_test_...` depuis le dashboard Stripe en mode test.
# PawaPay : jeton du bac à sable https://api.sandbox.pawapay.io
TEST_STRIPE_API_KEY=sk_test_replace_me
TEST_PAWAPAY_API_TOKEN=sandbox_token_replace_me
